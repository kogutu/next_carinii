'use client';

import React, { useState } from 'react';
import menu_items from './data/menu_items.json'
import {
    Menubar,
    MenubarContent,
    MenubarItem,
    MenubarMenu,
    MenubarSeparator,
    MenubarShortcut,
    MenubarSub,
    MenubarSubContent,
    MenubarSubTrigger,
    MenubarTrigger,
} from "@/components/ui/menubar"
import { ChevronDown } from 'lucide-react';
import MobileMenu from './menu_mobile';

interface HMenuProps {
    isMobileMenuOpen: boolean;
    onMobileMenuToggle?: (open: boolean) => void;
}
// Recursive component for menu items (desktop)
const MenuItems = ({ items, level = 0, onItemClick, parentLabel }: MenuItemsProps) => {
    return (
        <>
            {items.map((item) => {
                if (item.vis !== "1") return null;

                const hasChildren = item.child && item.child.length > 0;

                if (hasChildren) {
                    return (
                        <MenubarSub key={item.id}>
                            <MenubarSubTrigger className="flex items-center justify-between">
                                <span>{item.label}</span>
                            </MenubarSubTrigger>
                            <MenubarSubContent
                                className="top-0"
                                align="start"
                                sideOffset={-1}
                                collisionPadding={16}
                            >
                                {/* Dodaj nagłówek rodzica */}
                                {parentLabel && (
                                    <div className="px-2 py-1.5 text-sm font-semibold text-muted-foreground border-b mb-1">
                                        {parentLabel}
                                    </div>
                                )}
                                <MenuItems
                                    items={item.child!}
                                    level={level + 1}
                                    onItemClick={onItemClick}
                                    parentLabel={item.label}
                                />
                            </MenubarSubContent>
                        </MenubarSub>
                    );
                }

                return (
                    <MenubarItem
                        key={item.id}
                        asChild
                        className="flex items-center justify-between"
                        onClick={onItemClick}
                    >
                        <a href={item.link} target="_blank" rel="noopener noreferrer">
                            <span>{item.label}</span>
                        </a>
                    </MenubarItem>
                );
            })}
        </>
    );
};
export default function HMenu({ isMobileMenuOpen = false, onMobileMenuToggle }: HMenuProps) {
    const [internalMobileMenuOpen, setInternalMobileMenuOpen] = useState(false);

    const isOpen = onMobileMenuToggle ? isMobileMenuOpen : internalMobileMenuOpen;
    const setIsOpen = onMobileMenuToggle ? onMobileMenuToggle : setInternalMobileMenuOpen;

    const items = menu_items;
    const mainCategories = items.filter(item => item.vis === "1");

    return (
        <>
            {/* Desktop menu main parent*/}
            <Menubar className="hidden md:flex border-0 my-4 shadow-none justify-between">
                {mainCategories.map((category) => {
                    const hasChildren = category.child && category.child.length > 0;

                    return (
                        <MenubarMenu key={category.id}>
                            <MenubarTrigger className="
                                group
                                flex items-center justify-between gap-1
                                px-2 py-2 rounded-md
                                hover:bg-[#441c49] hover:text-white
                                data-[state=open]:bg-[#441c49] data-[state=open]:text-white
                                transition-colors duration-200
                                relative
                            ">
                                <span>{category.label}</span>
                                {hasChildren && (
                                    <ChevronDown className="
                                        h-4 w-4 
                                        transition-transform duration-200 
                                        group-data-[state=open]:rotate-180
                                    " />
                                )}
                            </MenubarTrigger>
                            {hasChildren && (
                                <MenubarContent
                                    className="top-0"
                                    align="start"
                                    sideOffset={-1}
                                    collisionPadding={16}
                                >
                                    <MenuItems items={category.child!} />
                                </MenubarContent>
                            )}
                        </MenubarMenu>
                    );
                })}
            </Menubar>

            {/* Mobile menu */}
            <MobileMenu
                items={items}
                isOpen={isOpen}
                onClose={() => setIsOpen(false)}
            />
        </>
    );
};